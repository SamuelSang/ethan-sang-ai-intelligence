.home-container {
  padding: 40rpx;
}
.header {
  text-align: center;
  margin-bottom: 60rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}
.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}
.device-selection {
  margin-bottom: 40rpx;
}
.section-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}
.device-grid {
  display: flex;
  justify-content: space-between;
}
.device-card {
  width: 200rpx;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.device-icon {
  font-size: 80rpx;
}
.device-name {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
}
.btn-pairing {
  width: 100%;
  height: 96rpx;
  background: #007aff;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
}
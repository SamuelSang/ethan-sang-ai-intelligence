<view class="guide-container">
  <view class="header">
    <text class="title">{{deviceType}} 验机指南</text>
    <text class="subtitle">请按顺序完成以下26项检测</text>
  </view>

  <view class="inspection-list">
    <block wx:for="{{inspectionItems}}" wx:key="id">
      <view class="inspection-item">
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-category">{{item.category}}</text>
        </view>
        <view class="item-status">
          <text class="status-text" wx:if="{{item.status === 'pending'}}">待检测</text>
          <text class="status-pass" wx:if="{{item.status === 'pass'}}">通过</text>
          <text class="status-fail" wx:if="{{item.status === 'fail'}}">失败</text>
        </view>
      </view>
    </block>
  </view>

  <button class="btn-complete" bindtap="onCompleteInspection">
    完成检测
  </button>
</view>
.guide-container {
  padding: 40rpx;
}
.header {
  margin-bottom: 40rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}
.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}
.inspection-list {
  margin-bottom: 40rpx;
}
.inspection-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}
.item-info {
  display: flex;
  flex-direction: column;
}
.item-name {
  font-size: 32rpx;
  color: #333;
}
.item-category {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.item-status {
  font-size: 28rpx;
}
.status-text {
  color: #999;
}
.status-pass {
  color: #07c160;
}
.status-fail {
  color: #ff4d4f;
}
.btn-complete {
  width: 100%;
  height: 96rpx;
  background: #007aff;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
}
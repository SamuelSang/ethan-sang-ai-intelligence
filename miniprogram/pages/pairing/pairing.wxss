.pairing-container {
  padding: 40rpx;
}
.header {
  text-align: center;
  margin-bottom: 60rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}
.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}
.btn-scan {
  width: 100%;
  height: 96rpx;
  background: #007aff;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
}
.result-section {
  margin-top: 60rpx;
  text-align: center;
}
.result-text {
  font-size: 32rpx;
  color: #333;
}
.btn-confirm {
  margin-top: 40rpx;
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
}